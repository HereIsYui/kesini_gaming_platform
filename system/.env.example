# 应用配置
NODE_ENV=development
PORT=7001
# 浏览器可访问的 API 域名在前端构建环境中配置：
# website: VITE_API_BASE
# backend: PUBLIC_API_BASE
# OAuth 回跳地址由浏览器当前域名生成。

# JWT配置
JWT_SECRET=kesini_game
JWT_EXPIRES_IN=7d
# 保留配置，不作为后台管理权限放行依据
ADMIN_UIDS=

# MySQL数据库配置
DB_HOST=192.168.0.106
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root_password
DB_DATABASE=kesini
DB_SYNCHRONIZE=true
DB_AUTO_LOAD_ENTITIES=true
DB_RETRY_DELAY=500
DB_RETRY_ATTEMPTS=10

# Redis配置 (预留能力，应用启动时不会主动连接)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# 充值配置
# 鱼排 goldFingerKey 通过后台“充值管理”配置，不建议写入环境变量或提交到仓库。

# 抽卡全局默认配置 (JSON格式)
# 后台“默认抽卡配置”可覆盖这里的代码/环境兜底；单个卡池的单独配置在“卡池管理”中维护。
STANDARD_POOL_RARITY_PROBABILITIES={"N":0.5,"R":0.3,"SR":0.15,"SSR":0.045,"UR":0.005}

# 抽卡全局默认保底配置 (JSON格式)
STANDARD_POOL_PITY_CONFIG={"enabled":true,"softPity":{"count":10,"guaranteedRarity":"SR"},"hardPity":{"count":90,"guaranteedRarity":"SSR"}}
