{
  "name": "kesini-gaming-platform",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "system",
    "backend"
  ],
  "scripts": {
    "system:dev": "npm --workspace system run start:dev",
    "system:build": "npm --workspace system run build",
    "system:test": "npm --workspace system run test",
    "system:seed:card-pools": "npm --workspace system run seed:card-pools --",
    "backend:dev": "npm --workspace backend run dev",
    "backend:build": "npm --workspace backend run build",
    "backend:preview": "npm --workspace backend run preview",
    "build": "npm run system:build && npm run backend:build",
    "test": "npm run system:test",
    "audit:critical": "npm audit --audit-level=critical"
  }
}
